# Script generation model
OPENAI_API_KEY=
GEMINI_API_KEY=
SCRIPT_MODEL=gemini-2.5-flash

# Image generation (Gemini / Nano Banana path)
GOOGLE_API_KEY=
IMAGE_MODEL_LIST=nano-banana-2.0,nano-banana-pro-preview,gemini-2.5-flash-image,gemini-2.0-flash-exp-image-generation
IMAGE_TIMEOUT_MS=45000
IMAGE_PRO_TIMEOUT_MS=90000

# Voice generation
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY=0.75
ELEVENLABS_STYLE=0.25

GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore

# voice provider: auto | edge | elevenlabs | gemini
VOICE_PROVIDER=auto
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz
EDGE_TTS_VOLUME=+0%

# rendering
SUBTITLE_ENABLED=true
EXTERNAL_SLIDES_DIR=/absolute/path/to/external-slides
FFMPEG_PATH=

# optional build dir override
PIPELINE_BUILD_DIR=build
